DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@kpf-fitnessstudio.de
CONTACT_AUTORESPONDER_ENABLED=False

# Google reCAPTCHA v2 Checkbox
RECAPTCHA_SITE_KEY=your-google-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-google-recaptcha-secret-key

# Trainer calendar sync
GYM_TIMEZONE=Europe/Berlin
TRAINER_CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/.../basic.ics
TRAINER_CALENDAR_TIMEOUT_SECONDS=5
TRAINER_CALENDAR_SYNC_INTERVAL_SECONDS=900
TRAINER_CALENDAR_VIEW_DAYS=10
TRAINER_CALENDAR_CACHE_SECONDS=900
LIVE_STATUS_CACHE_SECONDS=300
DJANGO_CACHE_DIR=/path/to/website_K+F/.django_cache
DJANGO_CACHE_MAX_ENTRIES=2000
